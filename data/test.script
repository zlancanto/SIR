CREATE MEMORY TABLE PUBLIC.CONCERTS(CREATEDAT TIMESTAMP NOT NULL,DATE TIMESTAMP NOT NULL,UPDATEDAT TIMESTAMP NOT NULL,ADMIN_ID BINARY(16),ID BINARY(16) NOT NULL PRIMARY KEY,ORGANIZER_ID BINARY(16),PLACE_ID BINARY(16),DESCRIPTION VARCHAR(1024),ARTIST VARCHAR(255),STATUS VARCHAR(255) NOT NULL,TITLE VARCHAR(255) NOT NULL,CHECK((PUBLIC.CONCERTS.STATUS) IN (('PENDING_VALIDATION'),('PUBLISHED'),('REJECTED'))))
CREATE MEMORY TABLE PUBLIC.PLACES(CAPACITY INTEGER,ZIPCODE INTEGER,CREATEDAT TIMESTAMP NOT NULL,UPDATEDAT TIMESTAMP NOT NULL,ID BINARY(16) NOT NULL PRIMARY KEY,ADDRESS VARCHAR(255),CITY VARCHAR(255),NAME VARCHAR(255))
CREATE MEMORY TABLE PUBLIC.REFRESH_TOKENS(CREATEDAT TIMESTAMP NOT NULL,EXPIRES_AT TIMESTAMP NOT NULL,REVOKED_AT TIMESTAMP,UPDATEDAT TIMESTAMP NOT NULL,ID BINARY(16) NOT NULL PRIMARY KEY,USER_ID BINARY(16) NOT NULL,TOKEN_HASH VARCHAR(88) NOT NULL,UNIQUE(TOKEN_HASH))
