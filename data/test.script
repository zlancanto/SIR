CREATE INDEX IDX_REFRESH_TOKENS_EXPIRES_AT ON PUBLIC.REFRESH_TOKENS(EXPIRES_AT)
CREATE MEMORY TABLE PUBLIC.TICKETS(PRICE NUMERIC(38,2) NOT NULL,SOLD BOOLEAN NOT NULL,CREATEDAT TIMESTAMP NOT NULL,UPDATEDAT TIMESTAMP NOT NULL,CONCERT_ID BINARY(16),CUSTOMER_ID BINARY(16),ID BINARY(16) NOT NULL PRIMARY KEY,BARCODE VARCHAR(255) NOT NULL,UNIQUE(BARCODE),CONSTRAINT FK4Q17SXDJIOD86PWE2PL0IHFNF FOREIGN KEY(CONCERT_ID) REFERENCES PUBLIC.CONCERTS(ID))
CREATE MEMORY TABLE PUBLIC.USERS(CREATEDAT TIMESTAMP NOT NULL,UPDATEDAT TIMESTAMP NOT NULL,ID BINARY(16) NOT NULL PRIMARY KEY,USER_TYPE VARCHAR(31) NOT NULL,EMAIL VARCHAR(255) NOT NULL,FIRSTNAME VARCHAR(255),LASTNAME VARCHAR(255),PASSWORD VARCHAR(255) NOT NULL,UNIQUE(EMAIL))
ALTER TABLE PUBLIC.CONCERTS ADD CONSTRAINT FK71PH2HL34U9XBINVN4NHDDSR8 FOREIGN KEY(ADMIN_ID) REFERENCES PUBLIC.USERS(ID)
ALTER TABLE PUBLIC.CONCERTS ADD CONSTRAINT FKMECSEK7PKNWS0J328B4P4P8BQ FOREIGN KEY(ORGANIZER_ID) REFERENCES PUBLIC.USERS(ID)
ALTER TABLE PUBLIC.CONCERTS ADD CONSTRAINT FKMMYYI4I1C21POTS8BXK7B1LBU FOREIGN KEY(PLACE_ID) REFERENCES PUBLIC.PLACES(ID)
ALTER TABLE PUBLIC.REFRESH_TOKENS ADD CONSTRAINT FK1LIH5Y2NPSF8U5O3VHDB9Y0OS FOREIGN KEY(USER_ID) REFERENCES PUBLIC.USERS(ID)
ALTER TABLE PUBLIC.TICKETS ADD CONSTRAINT FKCL6SHE6IC7DE97O1RYLI2G95I FOREIGN KEY(CUSTOMER_ID) REFERENCES PUBLIC.USERS(ID)
